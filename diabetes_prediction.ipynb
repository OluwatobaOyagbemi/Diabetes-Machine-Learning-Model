   "source": [
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier\n",
    "from sklearn.metrics import (accuracy_score, roc_auc_score, f1_score,\n",
    "                             classification_report, confusion_matrix, roc_curve)\n",
    "\n",
    "\n",
    "# Split BEFORE scaling\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X_sm, y_sm, test_size=0.2, random_state=42, stratify=y_sm\n",
    ")\n",
    "\n",
    "#  Scale AFTER split \n",
    "scaler = StandardScaler()\n",
    "X_train_sc = scaler.fit_transform(X_train)\n",
    "X_test_sc  = scaler.transform(X_test)      ,
    "\n",
    "# Train 3 models\n",
    "models = {\n",
    "    'Logistic Regression': LogisticRegression(max_iter=1000, random_state=42),\n",
    "    'Random Forest':       RandomForestClassifier(n_estimators=100, random_state=42),\n",
    "    'Gradient Boosting':   GradientBoostingClassifier(n_estimators=100, random_state=42)\n",
    "}\n",
    "\n",
    "results = {}\n",
    "for name, model in models.items():\n",
    "    model.fit(X_train_sc, y_train)\n",
    "    y_pred  = model.predict(X_test_sc)\n",
    "    y_proba = model.predict_proba(X_test_sc)[:, 1]\n",
    "    results[name] = {\n",
    "        'model':    model,\n",
    "        'y_pred':   y_pred,\n",
    "        'y_proba':  y_proba,\n",
    "        'accuracy': accuracy_score(y_test, y_pred),\n",
    "        'f1':       f1_score(y_test, y_pred),\n",
    "        'roc_auc':  roc_auc_score(y_test, y_proba)\n",
    "    }\n",
    "    print(f\"\\n{'─'*40}\")\n",
    "    print(f\"  {name}\")\n",
    "    print(f\"{'─'*40}\")\n",
    "    print(classification_report(y_test, y_pred,\n",
    "          target_names=['No Diabetes', 'Diabetes']))\n",
    "\n",
    "# Metrics bar chart ─────────────────────────────────────────────\n",
    "metrics_df = pd.DataFrame({\n",
    "    name: {\n",
    "        'Accuracy': v['accuracy'],\n",
    "        'F1 Score': v['f1'],\n",
    "        'ROC-AUC':  v['roc_auc']\n",
    "    }\n",
    "    for name, v in results.items()\n",
    "}).T\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
    "colors  = ['#2196F3', '#4CAF50', '#FF9800']\n",
    "metrics = ['Accuracy', 'F1 Score', 'ROC-AUC']\n",
    "\n",
    "for i, metric in enumerate(metrics):\n",
    "    bars = axes[i].bar(metrics_df.index, metrics_df[metric], color=colors, width=0.5)\n",
    "    axes[i].set_title(metric, fontsize=13, fontweight='bold')\n",
    "    axes[i].set_ylim(0.7, 1.0)\n",
    "    axes[i].set_ylabel('Score', fontsize=11)\n",
    "    axes[i].tick_params(axis='x', rotation=15)\n",
    "    for bar, val in zip(bars, metrics_df[metric]):\n",
    "        axes[i].text(bar.get_x() + bar.get_width()/2,\n",
    "                     val + 0.003, f'{val:.3f}',\n",
    "                     ha='center', fontsize=10, fontweight='bold')\n",
    "\n",
    "plt.suptitle('Model Comparison — Accuracy / F1 / ROC-AUC',\n",
    "             fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# ROC Curves ────────────────────────────────────────────────────\n",
    "plt.figure(figsize=(8, 6))\n",
    "colors = ['#2196F3', '#4CAF50', '#FF9800']\n",
    "for (name, v), color in zip(results.items(), colors):\n",
    "    fpr, tpr, _ = roc_curve(y_test, v['y_proba'])\n",
    "    plt.plot(fpr, tpr,\n",
    "             label=f\"{name} (AUC={v['roc_auc']:.3f})\",\n",
    "             color=color, lw=2)\n",
    "plt.plot([0,1],[0,1], 'k--', lw=1, label='Random Classifier')\n",
    "plt.title('ROC Curves — All Models', fontsize=13, fontweight='bold')\n",
    "plt.xlabel('False Positive Rate', fontsize=11)\n",
    "plt.ylabel('True Positive Rate', fontsize=11)\n",
    "plt.legend(fontsize=10)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "\n",
    "\n",
    "#  Pick best model ───────────────────────────────────────────────\n",
    "best_name = max(results, key=lambda x: results[x]['roc_auc'])\n",
    "print(f\"\\n🏆 Best Model: {best_name}\")\n",
    "print(f\"   Accuracy : {results[best_name]['accuracy']:.3f}\")\n",
    "print(f\"   F1 Score : {results[best_name]['f1']:.3f}\")\n",
    "print(f\"   ROC-AUC  : {results[best_name]['roc_auc']:.3f}\")"
   ]
  }
